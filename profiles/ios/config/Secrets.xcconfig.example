// Service keys for the app. Copy this file to `Secrets.xcconfig` (which is
// gitignored — NEVER commit it) and fill in real values. Leave a key blank if
// the app doesn't use that service.
//
// See the "Secrets & Service Keys" section of CLAUDE.md for how to wire these
// into the app (project.yml base config -> Info.plist -> runtime accessor) and
// for the separate list of CI secrets that go in GitHub Actions, not here.

// RevenueCat (subscriptions / IAP). RevenueCat dashboard -> API Keys -> the
// public "App Store" key for this app. Starts with `appl_`.
REVENUECAT_API_KEY = appl_xxxxxxxxxxxxxxxx

// Aptabase (privacy-first analytics). Aptabase dashboard -> App Settings ->
// App Key. Format like `A-EU-0000000000` / `A-US-...` / `A-DEV-...`.
APTABASE_APP_KEY = A-DEV-0000000000
